# Copy this file to .env for local development.
# On Render, set these same keys under your service's Environment tab instead —
# do not upload a real .env file there.

# --- Database (Turso) ---
# Leave both blank to develop locally against a plain SQLite file (local.db).
TURSO_DB_URL=
TURSO_AUTH_TOKEN=

# --- Auth ---
# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# --- CORS ---
# Your deployed Netlify URL(s), comma-separated if you have more than one
# (e.g. a custom domain + the netlify.app URL). Used to restrict which
# frontend origins may call this API.
FRONTEND_URL=https://your-site.netlify.app

# Used only by /share/episode/:id to build the canonical og:url — set this to
# wherever this backend itself is publicly reachable (your Render URL).
PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# --- Server ---
PORT=3000

# --- Seed script only (scripts/seed.js) ---
# Sets your REAL admin login password the first time you seed the database.
# Not read anywhere else, and not required after the first seed.
ADMIN_INITIAL_PASSWORD=
